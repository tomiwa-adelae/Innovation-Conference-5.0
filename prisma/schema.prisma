generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id          String   @id @default(uuid())
  fullName    String
  email       String   @unique
  phone       String
  institution String
  ticketType  String   @default("digital")
  heardAbout  String
  notes       String?
  attended    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
